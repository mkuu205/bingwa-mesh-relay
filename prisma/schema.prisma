generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  CONTROLLER
  WORKER
}

enum PresenceStatus {
  ONLINE
  OFFLINE
  BUSY
  IDLE
  EXECUTING
  RECONNECTING
  HEARTBEAT_LOST
}

model Device {
  id                String         @id @default(uuid())
  deviceId          String         @unique
  name              String?
  type              DeviceType
  publicKey         String?
  registeredAt      DateTime       @default(now())
  lastSeenAt        DateTime       @default(now())
  isTrusted         Boolean        @default(false)
  
  // Relations
  meshGroup         MeshGroup?     @relation("GroupDevices", fields: [meshGroupId], references: [id])
  meshGroupId       String?
  
  controlledGroups  MeshGroup[]    @relation("GroupController")
  
  pairingInitiated PairingHistory[] @relation("PairingInitiator")
  pairingReceived  PairingHistory[] @relation("PairingTarget")
  
  auditLogs        AuditLog[]
  relayEvents      RelayEvent[]
  metadata         DeviceMetadata?

  @@index([deviceId])
}

model MeshGroup {
  id           String   @id @default(uuid())
  name         String   @unique
  createdAt    DateTime @default(now())
  
  controllerId String
  controller   Device   @relation("GroupController", fields: [controllerId], references: [id])
  
  devices      Device[] @relation("GroupDevices")
}

model PairingHistory {
  id           String   @id @default(uuid())
  initiatorId  String
  initiator    Device   @relation("PairingInitiator", fields: [initiatorId], references: [id])
  targetId     String
  target       Device   @relation("PairingTarget", fields: [targetId], references: [id])
  status       String   // ACCEPTED, REJECTED, EXPIRED
  createdAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  deviceId  String?
  device    Device?  @relation(fields: [deviceId], references: [id])
  action    String
  payload   Json?
  createdAt DateTime @default(now())
}

model RelayEvent {
  id            String   @id @default(uuid())
  deviceId      String
  device        Device   @relation(fields: [deviceId], references: [id])
  eventType     String
  messageId     String?
  transactionId String?
  payload       Json?
  createdAt     DateTime @default(now())
}

model DeviceMetadata {
  id               String   @id @default(uuid())
  deviceId         String   @unique
  device           Device   @relation(fields: [deviceId], references: [id])
  batteryLevel     Int?
  isCharging       Boolean?
  signalStrength   Int?
  accessibility    Boolean?
  automationActive Boolean?
  queueSize        Int?
  currentTask      String?
  version          String?
  latency          Int?
  updatedAt        DateTime @updatedAt
}
