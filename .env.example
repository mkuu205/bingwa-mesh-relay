# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Database Configuration
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bingwa_mesh?schema=public"

# Redis Configuration
# Format: redis://HOST:PORT
REDIS_URL="redis://localhost:6379"

# Security
# Use long, random strings for secrets in production
JWT_SECRET="replace-with-secure-random-string"
JWT_REFRESH_SECRET="replace-with-secure-random-string"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# WebSocket
WS_PROTOCOL_VERSION="1.0.0"

# Monitoring
# Prometheus port (if running separate exporter)
PROMETHEUS_PORT=9090
